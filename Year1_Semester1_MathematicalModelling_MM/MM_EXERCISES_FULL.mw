<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart; with(DEtools): with(plots): with(linalg):
##### -----------------------------------------------------------
##### h) / x'(t) = x(t) - 4 * y(t)
#####<Font encoding="UTF-8">    \134 y'(t) = 5 * x(t) - 3 * y(t)</Font>
##### -----------------------------------------------------------

h_Equation1 := diff(x(t),t) = x(t)-4*y(t);
h_Equation2 := diff(y(t),t) = 5*x(t)-3*y(t);
Equation_System := h_Equation1, h_Equation2;

##### Extract values from system above
System_Matrix := matrix([[1, -4],[5, -3]]);
eigenvals(System_Matrix);

##### We have complex conjugate eigenvalues whose real part is -1 which is strictly
##### less than 0, so the origin (0, 0) is a spiral sink and asymptotically stable
print(&quot;We have complex conjugate eigenvalues whose real part is -1 which is strictly&quot;);
print(&quot;less than 0, so the origin (0, 0) is a spiral sink and asymptotically stable&quot;);
 
##### Draw the phase portrait 
Initial_Conditions:=[x(0)=0,y(0)=i]$i=1..5,[x(0)=-i,y(0)=0]$i=1..5,[x(0)=0,y(0)=-i]$i=1..5,[x(0)=i,y(0)=0]$i=1..5;
DEplot([Equation_System], [x(t), y(t)], t=-2..2, x=-5..5, y=-5..5, [Initial_Conditions], arrows=medium, linecolor=blue);</Text-field>
</Input>
