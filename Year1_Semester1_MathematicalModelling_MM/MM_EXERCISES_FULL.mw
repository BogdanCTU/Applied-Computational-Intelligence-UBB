<Group view="code" hide-input="false" labelreference="L1075" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">##### a) x_{n+1} = [(n+1)/(n+2)]^2 * x_{n} + [1/(n+2)] , where x_{0}=1
restart;

Equation_a:=x(n+1)=((n+1)/(n+2))^2*x(n)+1/(n+2);
simplify(%);
x(0) = 1;
Solution_a := rsolve({Equation_a, x(0)=1}, x(n));
Function_a := unapply(Solution_a, n);   # converts solution to afunction
seq(Function_a(n), n=0..10);</Text-field>
</Input>
