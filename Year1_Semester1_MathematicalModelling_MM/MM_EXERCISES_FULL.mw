<Group view="code" hide-input="false" labelreference="L1765" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart; with(DEtools): with(plots): with(linalg):
##### -----------------------------------------------------------
##### d)  / x'(t) = -2 * x(t)
##### <Font encoding="UTF-8">    \134 y'(t) = -4 * x(t) - 2 * y(t)</Font>
##### -----------------------------------------------------------

d_Equation1 := diff(x(t),t) = -2*x(t);
d_Equation2 := diff(y(t),t) = -4*x(t)-2*y(t);
Equation_System := d_Equation1, d_Equation2;

##### Extract values from system above
System_Matrix := matrix([[-2, 0],[-4, -2]]);
eigenvals(System_Matrix);

##### If both eigenvalues are strictly negative then the origin (0,0) is a sink node and locally asymptotically stable
print(&quot;Since both eigenvalues are strictly negative then the origin (0,0) is a sink node and locally asymptotically stable&quot;);

##### Draw the phase portrait 
Initial_Conditions:=[x(0)=0,y(0)=i]$i=1..5,[x(0)=-i,y(0)=0]$i=1..5,[x(0)=0,y(0)=-i]$i=1..5,[x(0)=i,y(0)=0]$i=1..5;
DEplot([Equation_System], [x(t), y(t)], t=-2..2, x=-5..5, y=-5..5, [Initial_Conditions], arrows=medium, linecolor=blue);</Text-field>
</Input>
