<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart; with(DEtools): with(plots): with(linalg):
##### -----------------------------------------------------------
##### e) / x'(t) = x(t) + 4 * y(t)
#####   <Font encoding="UTF-8"> \134 y'(t) = x(t) + y(t)</Font>
##### -----------------------------------------------------------

e_Equation1 := diff(x(t),t) = x(t)+4*y(t);
e_Equation2 := diff(y(t),t) = x(t)+y(t);
Equation_System := e_Equation1, e_Equation2;

##### Extract values from system above
System_Matrix := matrix([[1, 4],[1, 1]]);
eigenvals(System_Matrix);

##### The first eigenvalue is strictly positive and the second is strictly
##### negative then the origin (0,0) is a saddle point and unstable
print(&quot;The first eigenvalue is strictly positive and the second is strictly&quot;);
print(&quot;negative then the origin (0,0) is a saddle point and unstable&quot;);

##### Draw the phase portrait 
Initial_Conditions:=[x(0)=0,y(0)=i]$i=1..5,[x(0)=-i,y(0)=0]$i=1..5,[x(0)=0,y(0)=-i]$i=1..5,[x(0)=i,y(0)=0]$i=1..5;
DEplot([Equation_System], [x(t), y(t)], t=-2..2, x=-5..5, y=-5..5, [Initial_Conditions], arrows=medium, linecolor=blue);</Text-field>
</Input>
