<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart; with(DEtools): with(plots): with(linalg):
##### -----------------------------------------------------------
##### b) / x'(t) = -2 * x(t) + y(t) + 2
#####<Font encoding="UTF-8">    \134 y'(t) = x(t) * y(t)</Font>
##### -----------------------------------------------------------

b_Function1 := (x,y) -&gt; -2*x+y+2;
b_Function2 := (x,y) -&gt; x*y;
b_Equation1 := diff(x(t),t) = b_Function1(x(t), y(t));
b_Equation2 := diff(y(t),t) = b_Function2(x(t), y(t));
b_Equation_System := b_Equation1, b_Equation2;

b_Equilibrium_Points := solve({b_Function1(x, y)=0, b_Function2(x, y)=0}, {x, y});
b_Jacobian := jacobian([b_Function1(x,y), b_Function2(x,y)], [x,y]);

##### EQUILIBRIUM POINTS
b_Jacobian_Matrix_Point1 := subs(b_Equilibrium_Points[1,1], b_Equilibrium_Points[1,2], eval(b_Jacobian));
eigenvals(b_Jacobian_Matrix_Point1);
evalf(eigenvals(b_Jacobian_Matrix_Point1));
##### The first eigenvalue is strictly positive and the second is strictly
##### negative then the origin (0,0) is a saddle point and unstable

b_Jacobian_Matrix_Point2 := subs(b_Equilibrium_Points[2,1], b_Equilibrium_Points[2,2], eval(b_Jacobian));
eigenvals(b_Jacobian_Matrix_Point2);
##### We have complex conjugate eigenvalues whose real part is 1/2 which is strictly
##### greater than 0, so the equilibrium point (1, 0) is a spiral source and unstable

##### DRAW THE PHAISE PORTRAIT
Initial_Conditions := [x(0)=-1,y(0)=1],[x(0)=-0.5,y(0)=1],[x(0)=1,y(0)=1],[x(0)=1,y(0)=3],[x(0)=2,y(0)=0.5],[x(0)=-1,y(0)=-1],[x(0)=-0.5,y(0)=-1],[x(0)=-1,y(0)=-2.5],[x(0)=1,y(0)=-1],[x(0)=1.5,y(0)=-1],[x(0)=1,y(0)=-2.5];
DEplot([b_Equation_System],[x(t),y(t)],t=-10..10,x=-10..10,y=-10..10,[Initial_Conditions],linecolor=blue,stepsize=0.1);</Text-field>
</Input>
