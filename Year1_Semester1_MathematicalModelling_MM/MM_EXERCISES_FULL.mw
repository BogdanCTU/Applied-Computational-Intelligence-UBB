<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart;

##### --- Formula: k = ln(2) / Half_Life ---

##### --- Part (a): Carbon-14 ---
T12_C14 := 5730;
k_C14 := ln(2) / T12_C14;
print(&quot;Decay constant for C-14:&quot;, evalf(k_C14));

##### --- Part (b): Uranium-238 ---
T12_U238 := 4.468 * 10^9;
k_U238 := ln(2) / T12_U238;
print(&quot;Decay constant for U-238:&quot;, evalf(k_U238));

##### --- Part (c): Uranium-235 ---
T12_U235 := 706 * 10^6;
k_U235 := ln(2) / T12_U235;
print(&quot;Decay constant for U-235:&quot;, evalf(k_U235));</Text-field>
</Input>
