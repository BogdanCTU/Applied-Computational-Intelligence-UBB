<Group view="code" hide-input="false" labelreference="L1928" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart; with(DEtools): with(plots): with(linalg):
##### -----------------------------------------------------------
##### d) / x'(t) = x^2(t) - y^2(t)
#####    <Font encoding="UTF-8">\134 y'(t) = x(t) * y(t) - 1
</Font>##### -----------------------------------------------------------

d_Function1 := (x,y) -&gt; x^2-y^2;
d_Function2 := (x,y) -&gt; x*y-1;
d_Equation1 := diff(x(t),t) = d_Function1(x(t), y(t));
d_Equation2 := diff(y(t),t) = d_Function2(x(t), y(t));
d_Equation_System := d_Equation1, d_Equation2;

d_Equilibrium_Points := solve({d_Function1(x, y)=0, d_Function2(x, y)=0}, {x, y});
evalf({_Equilibrium_Points[1,1],_Equilibrium_Points[1,2]});
d_Jacobian_Matrix_Point1 := jacobian([d_Function1(x,y), d_Function2(x,y)], [x,y]);
d_Jacobian := jacobian([d_Function1(x,y), d_Function2(x,y)], [x,y]);
##### The first solution is formed of complex numbers (i), so we exclude it.

##### EQUILIBRIUM POINTS

d_Jacobian_Matrix_Point1 := subs(d_Equilibrium_Points[2,1], d_Equilibrium_Points[2,2], eval(d_Jacobian));
eigenvals(d_Jacobian_Matrix_Point1);
##### We have complex conjugate eigenvalues whose real part is 3/2 which is strictly
##### greater than 0, so the equilibrium point (1, 1) is a spiral source and unstable

d_Jacobian_Matrix_Point2 := subs(d_Equilibrium_Points[3,1], d_Equilibrium_Points[3,2], eval(d_Jacobian));
eigenvals(d_Jacobian_Matrix_Point2);
##### We have complex conjugate eigenvalues whose real part is -3/2 which is strictly less than
##### 0, so the equilibrium point (-1, -1) is a spiral sink and locally asymtotically stable

##### DRAW THE PHAISE PORTRAIT
Initial_Conditions := [x(0)=-1,y(0)=1],[x(0)=-0.5,y(0)=1],[x(0)=1,y(0)=1],[x(0)=1,y(0)=3],[x(0)=2,y(0)=0.5],[x(0)=-1,y(0)=-1],[x(0)=-0.5,y(0)=-1],[x(0)=-1,y(0)=-2.5],[x(0)=1,y(0)=-1],[x(0)=1.5,y(0)=-1],[x(0)=1,y(0)=-2.5];
DEplot([d_Equation_System],[x(t),y(t)],t=-10..10,x=-10..10,y=-10..10,[Initial_Conditions],linecolor=blue,stepsize=0.1);</Text-field>
</Input>
