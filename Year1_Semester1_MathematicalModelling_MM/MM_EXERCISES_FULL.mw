<Group view="code" hide-input="false" labelreference="L1971" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">##### -----------------------------------------------------------
##### b) Make some numerical simulations
##### -----------------------------------------------------------

r1 := 0.5; K1 := 10; b12 := 0.2;
r2 := 0.3; K2 := 8; b21 := 0.1;

Equilibrium_Points; EigenValues1; EigenValues2; EigenValues3; EigenValues4;

DEplot([Equation_System],[x(t),y(t)],t=0..50,[[x(0)=3,y(0)=1]],stepsize=0.1,linecolor=blue);

gx := DEplot([Equation_System],[x(t),y(t)],t=0..50,[[x(0)=3,y(0)=1]],stepsize=0.1,linecolor=blue,scene=[t,x(t)]):
gy := DEplot([Equation_System],[x(t),y(t)],t=0..50,[[x(0)=3,y(0)=1]],stepsize=0.1,linecolor=red,scene=[t,y(t)]):
display(gx,gy);

Initial_Conditions := [x(0)=1, y(0)=1],[x(0)=5, y(0)=2],[x(0)=8, y(0)=6]:
gx := DEplot([Equation_System],[x(t),y(t)],t=0..50,[Initial_Conditions],stepsize=0.1,linecolor=blue,scene=[t,x(t)]):
gy := DEplot([Equation_System],[x(t),y(t)],t=0..50,[Initial_Conditions],stepsize=0.1,linecolor=red,scene=[t,y(t)]):
display(gx,gy);</Text-field>
</Input>
