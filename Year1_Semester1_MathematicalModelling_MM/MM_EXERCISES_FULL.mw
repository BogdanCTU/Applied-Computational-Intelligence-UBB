<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart; with(DEtools): with(plots): with(linalg):
##### -----------------------------------------------------------
##### c) / x'(t) = y^2(t)
#####    <Font encoding="UTF-8">\134 y'(t) = x(t)
</Font>##### -----------------------------------------------------------

c_Function1 := (x,y) -&gt; y^2;
c_Function2 := (x,y) -&gt; x;
c_Equation1 := diff(x(t),t) = c_Function1(x(t), y(t));
c_Equation2 := diff(y(t),t) = c_Function2(x(t), y(t));
c_Equation_System := c_Equation1, c_Equation2;

c_Equilibrium_Points := solve({c_Function1(x, y)=0, c_Function2(x, y)=0}, {x, y});
c_Jacobian := jacobian([c_Function1(x,y), c_Function2(x,y)], [x,y]);

##### EQUILIBRIUM POINTS
c_Jacobian_Matrix_Point1 := subs(c_Equilibrium_Points, eval(c_Jacobian));
eigenvals(c_Jacobian_Matrix_Point1);

##### When eigenvalues are 0, the linear approximation is inconclusive for determining
#####  asymptotic stability.However, we see that x(t) is always increasing (y(t)^2 &gt; 0).
##### This suggests the origin is unstable, as trajectories will generally move away 
#####  from the origin in the positive x-direction, as seen in the phase portrait.

##### DRAW THE PHAISE PORTRAIT
Initial_Conditions := [x(0)=-1,y(0)=1],[x(0)=-0.5,y(0)=1],[x(0)=1,y(0)=1],[x(0)=1,y(0)=3],[x(0)=2,y(0)=0.5],[x(0)=-1,y(0)=-1],[x(0)=-0.5,y(0)=-1],[x(0)=-1,y(0)=-2.5],[x(0)=1,y(0)=-1],[x(0)=1.5,y(0)=-1],[x(0)=1,y(0)=-2.5];
DEplot([c_Equation_System],[x(t),y(t)],t=-10..10,x=-10..10,y=-10..10,[Initial_Conditions],linecolor=blue,stepsize=0.1);</Text-field>
</Input>
