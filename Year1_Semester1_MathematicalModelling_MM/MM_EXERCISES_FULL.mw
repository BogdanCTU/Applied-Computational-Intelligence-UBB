<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart; with(DEtools): with(plots): with(linalg):

##### -----------------------------------------------------------
##### f) / x'(t) = 2 * x(t) - y(t)
#####<Font encoding="UTF-8">    \134 y'(t) = x(t) + 2 * y(t)</Font>
##### -----------------------------------------------------------

f_Equation1 := diff(x(t),t) = 2*x(t)-1*y(t);
f_Equation2 := diff(y(t),t) = x(t)+2*y(t);
Equation_System := f_Equation1, f_Equation2;

##### Extract values from system above
System_Matrix := matrix([[2, -1],[1, 2]]);
eigenvals(System_Matrix);

##### We have complex conjugate eigenvalues whose real part is 2 which is strictly
##### greater than 0, so the origin (0, 0) is a spiral source and unstable
print(&quot;We have complex conjugate eigenvalues whose real part is 2 which is strictly&quot;);
print(&quot;greater than 0, so the origin (0, 0) is a spiral source and unstable&quot;);

##### Draw the phase portrait 
Initial_Conditions:=[x(0)=0,y(0)=i]$i=1..5,[x(0)=-i,y(0)=0]$i=1..5,[x(0)=0,y(0)=-i]$i=1..5,[x(0)=i,y(0)=0]$i=1..5;
DEplot([Equation_System], [x(t), y(t)], t=-2..2, x=-5..5, y=-5..5, [Initial_Conditions], arrows=medium, linecolor=blue);</Text-field>
</Input>
