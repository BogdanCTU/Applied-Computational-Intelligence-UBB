<Group view="code" hide-input="false" labelreference="L1668" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart;

##### -----------------------------------------------------------
##### 1. Define the Mathematical Model
##### Differential Equation for growth rate: x'(t) = k * x(t)
##### DE for decay rate: x'(t) = -k * x(t) (see S5 - EXERCISE 2)
##### -----------------------------------------------------------
DE_Model := diff(x(t), t) = k * x(t);

# Solve the differential equation with initial condition x(0) = x0
General_Sol := dsolve({DE_Model, x(0) = x0}, x(t));

# Convert the solution into a function x_func(t, x0, k) for easier reuse
# rhs() extracts the right-hand side of the solution: x0 * exp(k*t) (curs 10)
x_func := unapply(rhs(General_Sol), t, x0, k);

##### -----------------------------------------------------------
##### 2. Find the Growth Constant (k)
##### Given: x(0) = 1500, x(1) = 2000
##### -----------------------------------------------------------
Initial_Bacteria := 1500;
Bacteria_at_1h := 2000;

# Set up the equation: Population at t=1 must equal 2000
Eq_find_k := x_func(1, Initial_Bacteria, k) = Bacteria_at_1h;

# Solve for k
k_val := solve(Eq_find_k, k);

print(&quot;The growth constant k is:&quot;, evalf(k_val));

##### -----------------------------------------------------------
##### Part (a): How many bacteria after 4 hours?
##### Use the found k_val and the initial population of 1500
##### -----------------------------------------------------------
Bacteria_at_4h := x_func(4, Initial_Bacteria, k_val);

print(&quot;a) Bacteria after 4 hours:&quot;, evalf(Bacteria_at_4h));

##### -----------------------------------------------------------
##### Part (b): Initial bacteria needed to have 3000 in 2 hours
##### Solve for a NEW x0, keeping the same k_val and t=2
##### -----------------------------------------------------------
Target_Bacteria := 3000;
Target_Time := 2;

# Equation: x(2) = 3000, solve for variable 'New_x0'
Eq_find_x0 := x_func(Target_Time, New_x0, k_val) = Target_Bacteria;

Required_Initial := solve(Eq_find_x0, New_x0);

print(&quot;b) Required initial bacteria:&quot;, evalf(Required_Initial));

</Text-field>
</Input>
