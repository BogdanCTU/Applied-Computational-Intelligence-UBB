##### -----------------------------------------------------------
##### g)   / x'(t) = -y(t)
#####<Font encoding="UTF-8">      \134 y'(t) = x(t)</Font>
##### -----------------------------------------------------------

g_Equation1 := diff(x(t),t) = -y(t);
g_Equation2 := diff(y(t),t) = x(t);
Equation_System := g_Equation1, g_Equation2;

##### Extract values from system above
System_Matrix := matrix([[0, -1],[1, 0]]);
eigenvals(System_Matrix);

##### We have complex conjugate eigenvalues whose real part is 0,
##### so origin is a center and is locally asymptotically stable
print(&quot;We have complex conjugate eigenvalues whose real part is 0&quot;);
print(&quot;so origin is a center and is locally asymptotically stable&quot;);

##### Draw the phase portrait 
Initial_Conditions:=[x(0)=0,y(0)=i]$i=1..5,[x(0)=-i,y(0)=0]$i=1..5,[x(0)=0,y(0)=-i]$i=1..5,[x(0)=i,y(0)=0]$i=1..5;
