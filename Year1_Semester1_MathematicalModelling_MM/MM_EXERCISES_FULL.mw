<Group view="code" hide-input="false" labelreference="L1654" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart;

##### -----------------------------------------------------------
##### a): Find the general solution of the differential equation
##### -----------------------------------------------------------

differential_equation_a := x^2 * diff(y(x), x$2) - 2 * x * diff(y(x), x) + 2 * y(x) = 0;
dsolve(differential_equation_a, y(x));

##### -----------------------------------------------------------
##### b): Find the solution of the equation which satisfies
#####     initial conditions
##### -----------------------------------------------------------

Initial_Conditions := y(1)=2, D(y)(1)=3;
print(&quot;Solution for initial conditions:&quot;);
dsolve({differential_equation_a, Initial_Conditions}, y(x));


</Text-field>
</Input>
