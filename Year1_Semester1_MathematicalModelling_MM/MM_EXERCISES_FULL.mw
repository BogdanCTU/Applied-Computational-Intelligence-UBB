<Input><Text-field style="Text" bold="true" layout="Normal"><Font bold="true">S3 - EXERCISE 3
HINT KEY WORDS: difference equation, sequence, growth rate, equilibrium points, stability, numerical simulations, Schur-Cohn criterion</Font></Text-field>
</Input>
</Group></Presentation-Block><Presentation-Block>
<Group view="presentation" inline-output="false" labelreference="L542" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
