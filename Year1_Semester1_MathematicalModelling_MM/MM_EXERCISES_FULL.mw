<Group view="code" hide-input="false" labelreference="L1877" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart; with(DEtools): with(plots): with(linalg):
##### -----------------------------------------------------------
##### a) / x'(t) = y(t)
#####<Font encoding="UTF-8">    \134 y'(t) = x(t) * (1 - x^2(t)) + y(t)</Font>
##### -----------------------------------------------------------

a_Function1 := (x,y) -&gt; y;
a_Function2 := (x,y) -&gt; x*(1-x^2)+y;
a_Equation1 := diff(x(t),t) = a_Function1(x(t), y(t));
a_Equation2 := diff(y(t),t) = a_Function2(x(t), y(t));
a_Equation_System := a_Equation1, a_Equation2;

a_Equilibrium_Points := solve({a_Function1(x, y)=0, a_Function2(x, y)=0}, {x, y});
a_Jacobian := jacobian([a_Function1(x,y), a_Function2(x,y)], [x,y]);

##### EQUILIBRIUM POINTS
a_Jacobian_Matrix_Point1 := subs(a_Equilibrium_Points[1,1], a_Equilibrium_Points[1,2], eval(a_Jacobian));
eigenvals(a_Jacobian_Matrix_Point1);
evalf(eigenvals(a_Jacobian_Matrix_Point1));
##### The first eigenvalue is strictly positive and the second is strictly
##### negative then the origin (0,0) is a saddle point and unstable

a_Jacobian_Matrix_Point2 := subs(a_Equilibrium_Points[2,1], a_Equilibrium_Points[2,2], eval(a_Jacobian));
eigenvals(a_Jacobian_Matrix_Point2);
##### We have complex conjugate eigenvalues whose real part is 1/2 which is strictly
##### greater than 0, so the equilibrium point (1, 0) is a spiral source and unstable

a_Jacobian_Matrix_Point3 := subs(a_Equilibrium_Points[3,1], a_Equilibrium_Points[3,2], eval(a_Jacobian));
eigenvals(a_Jacobian_Matrix_Point3);
##### Same result as for the previous equilibrium point, so the equilibrium point (-1, 0) is a spiral source and unstable

##### DRAW THE PHAISE PORTRAIT
Initial_Conditions := [x(0)=-1,y(0)=1],[x(0)=-0.5,y(0)=1],[x(0)=1,y(0)=1],[x(0)=1,y(0)=3],[x(0)=2,y(0)=0.5],[x(0)=-1,y(0)=-1],[x(0)=-0.5,y(0)=-1],[x(0)=-1,y(0)=-2.5],[x(0)=1,y(0)=-1],[x(0)=1.5,y(0)=-1],[x(0)=1,y(0)=-2.5];
DEplot([a_Equation_System], [x(t),y(t)],t=-10..10,x=-3..3,y=-3..3, [Initial_Conditions], linecolor=blue, stepsize=0.1);</Text-field>
</Input>
