</Input>
</Group>
<Group view="code" hide-input="false" labelreference="L1986" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Newton's Law of Cooling - Initial Value Problem (IVP)
# Model based on S4-EXERCISE 2 and S5-EXERCISE 4
restart;

# 1. Define the Differential Equation
# T'(t) = -k * (T(t) - Tout)
# Where Tout = 20 (Room Temp)
Tout := 20;
deq := diff(T(t), t) = -k * (T(t) - Tout);

# 2. Solve the IVP with Initial Temperature T(0) = 60
# This uses the dsolve method shown in the course documents
init_cond := T(0) = 60;
sol_general := dsolve({deq, init_cond}, T(t));

# 3. Create a function from the solution for evaluation
# Similar to the 'unapply' method used in Seminar 4
T_func := unapply(rhs(sol_general), t, k);

# 4. Find the thermic coefficient 'k' 
# Using the data: T(2) = 45
k_val := solve(T_func(2, k) = 45, k);

# 5. Define the final solution function with the found k value
# This implements the analytical solution for this specific object
final_sol := t -&gt; T_func(t, k_val);

# --- Part (a): Temperature after 3 hours ---
temp_3h := evalf(final_sol(3));

# --- Part (b): Time to reach 30 C ---
# Use fsolve to find the specific time root
time_30c := fsolve(final_sol(t) = 30, t);

# Display Results
print(&quot;Object temperature after 3 hours (Celsius):&quot;, temp_3h);
print(&quot;Time required to reach 30 C (Hours):&quot;, time_30c);

# Optional: Plot the cooling curve
plot(final_sol(t), t = 0 .. 10, title = &quot;Object Cooling Over Time&quot;, labels = [&quot;Time (h)&quot;, &quot;Temp (C)&quot;], color = blue, thickness = 2);</Text-field>
</Input>
