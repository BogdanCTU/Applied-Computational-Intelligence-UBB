<Group view="code" hide-input="false" labelreference="L1690" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart; with(DEtools): with(plots): with(linalg):
##### -----------------------------------------------------------
##### a) / x'(t) = 16 * y^3 - x
#####<Font encoding="UTF-8">    \134 y'(t) = </Font>x^3 - 16 * y
##### -----------------------------------------------------------

a_Function1 := (x,y) -&gt; 16 * y^3 - x;
a_Function2 := (x,y) -&gt; x^3 - 16 * y;
a_Equation1 := diff(x(t),t) = a_Function1(x(t), y(t));
a_Equation2 := diff(y(t),t) = a_Function2(x(t), y(t));
a_Equation_System := a_Equation1, a_Equation2;

a_Equilibrium_Points := solve({a_Function1(x, y)=0, a_Function2(x, y)=0}, {x, y});
a_Jacobian := jacobian([a_Function1(x,y), a_Function2(x,y)], [x,y]);

##### EQUILIBRIUM POINTS

##### -----------------------------------------------------------
##### NOTE: Writing EquiP[1] same as wrt [EquiP[1,1], EquiP[1,2]]
##### -----------------------------------------------------------
a_Jacobian_Matrix_Point1 := subs(a_Equilibrium_Points[1], eval(a_Jacobian));
Eigenvals_1 := evalf(eigenvals(a_Jacobian_Matrix_Point1));
##### Both eigenvalues are strictly negative then the origin
##### (0,0) is a sink node andlocally asymtotically stable

a_Jacobian_Matrix_Point2 := subs(a_Equilibrium_Points[2], eval(a_Jacobian));
Eigenvals_2 := evalf(eigenvals(a_Jacobian_Matrix_Point2));
##### The first eigenvalue is strictly positive and the second is strictly negative
##### then the equilibrium point (2,1/2) is a saddle point and unstable

a_Jacobian_Matrix_Point3 := subs(a_Equilibrium_Points[3], eval(a_Jacobian));
Eigenvals_3 := evalf(eigenvals(a_Jacobian_Matrix_Point3));
##### The first eigenvalue is strictly positive and the second is strictly negative
##### then the equilibrium point (-2,-1/2) is a saddle point and unstable

</Text-field>
</Input>
